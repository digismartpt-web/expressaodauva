---
import { restaurantConfig } from '../data/config.js';

const menuItems = [
  { href: '/#ementa', text: 'Ementa' },
  { href: '/#reservas', text: 'Reservas' },
  { href: '/#takeaway', text: 'Click & Collect' },
  { href: '/#contactos', text: 'Contactos' },
];
---

<header id="main-header" class="fixed top-0 w-full bg-white z-50 transition-all duration-300 border-b border-transparent">
  <div id="header-container" class="container mx-auto px-6 md:px-8">
    <nav id="nav-container" class="flex flex-col items-center justify-center transition-all duration-300 pt-6 pb-2 md:pt-10 md:pb-4">

      <!-- Logo / Name -->
      <div id="logo-section" class="flex items-center gap-4 mb-4 md:mb-6 md:flex-col transition-all duration-300">
        <a href="/#home" id="logo-link" class="flex flex-col items-center text-center group transition-all duration-300">
          <div id="logo-img-wrapper" class="mb-3 transition-all duration-300">
            <img
              src="/images/social/logo-removebg-preview(1).png"
              alt="Expressão da Uva"
              id="logo-img"
              class="h-24 md:h-32 w-auto object-contain block"
            />
          </div>
          <span id="logo-text" class="font-serif text-2xl md:text-5xl tracking-wider text-neutral-900 transition-all duration-300">{restaurantConfig.name}</span>
          <span id="logo-sub" class="text-xs md:text-sm tracking-[0.3em] uppercase text-neutral-500 mt-2 transition-all duration-300">Bar de Vinhos</span>
        </a>
        <!-- Mobile-only Pedir Online button -->
        <a
          href="https://www.instagram.com/expressao_da_uva/reels/"
          target="_blank"
          rel="noopener noreferrer"
          id="pedir-mobile"
          class="pedir-btn md:hidden px-3 py-1.5 bg-gold text-white text-[9px] font-bold uppercase tracking-widest rounded-full hover:bg-neutral-900 transition-all duration-300 shadow-md whitespace-nowrap"
        >
          Pedir Online
        </a>
      </div>

      <!-- Desktop Menu -->
      <div id="desktop-menu" class="hidden md:flex items-center space-x-12 opacity-100 transition-all duration-300">
        {menuItems.map(item => (
          <div class="flex flex-col items-center relative">
            <a
              href={item.href}
              class="text-xs md:text-sm uppercase tracking-[0.2em] text-neutral-600 hover:text-gold transition-colors duration-300 leading-tight"
            >
              {item.text}
            </a>
            {item.text === 'Click & Collect' && (
              <div class="absolute top-[110%] left-0 w-full">
                <a
                  href="https://www.instagram.com/expressao_da_uva/reels/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="pedir-btn block w-full text-center px-3 py-0.5 bg-gold text-white text-[8px] font-bold uppercase tracking-widest rounded-full hover:bg-neutral-900 transition-colors duration-300 shadow-sm whitespace-nowrap"
                >
                  Pedir Online
                </a>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden absolute right-6 top-6 p-2 text-neutral-900 transition-all duration-300 z-[60] touch-manipulation"
        aria-label="Menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<!-- Spacer initial -->
<div class="h-[220px] md:h-[360px] bg-white"></div>

<!-- Mobile Menu Full Screen Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-neutral-900 z-[200] hidden opacity-0 transition-opacity duration-300">
  <div class="h-full flex flex-col justify-center items-center">
    <button
      id="close-menu-button"
      class="absolute top-6 right-6 p-2 text-white"
      aria-label="Fechar menu"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <nav class="text-center space-y-8">
      <a href="/#home" class="block text-3xl font-serif text-white tracking-wider hover:text-gold transition-colors">
        Início
      </a>
      {menuItems.map(item => (
        <div class="flex flex-col items-center gap-3">
          <a
            href={item.href}
            class="block text-3xl font-serif text-white tracking-wider hover:text-gold transition-colors"
          >
            {item.text}
          </a>
          {item.text === 'Click & Collect' && (
            <a
              href="https://www.instagram.com/expressao_da_uva/reels/"
              target="_blank"
              rel="noopener noreferrer"
              class="px-8 py-3 bg-gold text-white text-sm font-bold uppercase tracking-widest rounded-full hover:bg-white hover:text-gold transition-all duration-300 shadow-lg"
            >
              Pedir Online
            </a>
          )}
        </div>
      ))}
    </nav>

    <div class="absolute bottom-10 flex gap-8">
      <a href={restaurantConfig.contact.instagram} target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      </a>
      <a href={restaurantConfig.contact.facebook} target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
    </div>
  </div>
</div>

<style>
  @keyframes pedir-arrive {
    0%   { opacity: 0; transform: translateY(10px) scale(0.9); }
    70%  { opacity: 1; transform: translateY(-3px) scale(1.04); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .pedir-btn {
    animation: pedir-arrive 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: 0.3s;
  }
</style>

<script>
  const header        = document.getElementById('main-header')!;
  const logoImgWrapper = document.getElementById('logo-img-wrapper')!;
  const navContainer  = document.getElementById('nav-container')!;
  const logoSection   = document.getElementById('logo-section')!;
  const logoLink      = document.getElementById('logo-link')!;
  const logoText      = document.getElementById('logo-text')!;
  const logoSub       = document.getElementById('logo-sub')!;
  const desktopMenu   = document.getElementById('desktop-menu');
  const pedirMobile   = document.getElementById('pedir-mobile');
  const mobileBtn     = document.getElementById('mobile-menu-button');

  const THRESHOLD = 50;
  let scrolled = false;

  function applyScrolled() {
    // Header ombre
    header.style.boxShadow = '0 1px 4px rgba(0,0,0,0.08)';

    // Logo image disparaît
    logoImgWrapper.style.display = 'none';

    // Nav → ligne horizontale
    navContainer.style.flexDirection  = 'row';
    navContainer.style.alignItems     = 'center';
    navContainer.style.justifyContent = 'space-between';
    navContainer.style.paddingTop     = '0.6rem';
    navContainer.style.paddingBottom  = '0.6rem';

    // Bloc logo : plus de marge en bas
    logoSection.style.marginBottom = '0';

    // Nom + Bar de Vinhos : alignés à gauche
    logoLink.style.alignItems = 'flex-start';
    logoLink.style.textAlign  = 'left';

    // Textes plus petits
    logoText.style.fontSize   = '1.25rem';
    logoText.style.lineHeight = '1.2';
    logoSub.style.marginTop   = '0';
    logoSub.style.fontSize    = '0.6rem';

    // Menu desktop : espacement réduit
    if (desktopMenu) desktopMenu.style.gap = '2rem';

    // Bouton Pedir mobile : plus petit (pas masqué)
    if (pedirMobile) {
      pedirMobile.style.fontSize  = '0.5rem';
      pedirMobile.style.padding   = '0.2rem 0.5rem';
    }

    // Bouton hamburger repositionné
    if (mobileBtn) mobileBtn.style.top = '0.8rem';
  }

  function resetScrolled() {
    header.style.boxShadow = '';

    logoImgWrapper.style.display = '';

    navContainer.style.flexDirection  = '';
    navContainer.style.alignItems     = '';
    navContainer.style.justifyContent = '';
    navContainer.style.paddingTop     = '';
    navContainer.style.paddingBottom  = '';

    logoSection.style.marginBottom = '';

    logoLink.style.alignItems = '';
    logoLink.style.textAlign  = '';

    logoText.style.fontSize   = '';
    logoText.style.lineHeight = '';
    logoSub.style.marginTop   = '';
    logoSub.style.fontSize    = '';

    if (desktopMenu) desktopMenu.style.gap = '';

    if (pedirMobile) {
      pedirMobile.style.fontSize = '';
      pedirMobile.style.padding  = '';
    }

    if (mobileBtn) mobileBtn.style.top = '';
  }

  function updateHeader() {
    const shouldScroll = window.scrollY > THRESHOLD;
    if (shouldScroll === scrolled) return;
    scrolled = shouldScroll;
    shouldScroll ? applyScrolled() : resetScrolled();
  }

  // Listen to native scroll event AND poll via rAF (for Lenis compatibility on mobile)
  window.addEventListener('scroll', updateHeader, { passive: true });
  (function rafLoop() { updateHeader(); requestAnimationFrame(rafLoop); })();

  // ── Mobile menu ──
  const mobileMenu      = document.getElementById('mobile-menu');
  const closeMenuButton = document.getElementById('close-menu-button');

  function openMenu() {
    if (!mobileMenu) return;
    mobileMenu.classList.remove('hidden');
    // double rAF ensures display:block is applied before opacity transition starts
    requestAnimationFrame(() => requestAnimationFrame(() => mobileMenu.classList.remove('opacity-0')));
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!mobileMenu) return;
    mobileMenu.classList.add('opacity-0');
    setTimeout(() => mobileMenu.classList.add('hidden'), 300);
    document.body.style.overflow = '';
  }

  mobileBtn?.addEventListener('click', openMenu);
  closeMenuButton?.addEventListener('click', closeMenu);
  mobileMenu?.querySelectorAll('a').forEach(l => l.addEventListener('click', closeMenu));

  document.querySelectorAll('a[href^="/#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      const href = (this as HTMLAnchorElement).getAttribute('href');
      if (href?.startsWith('/#')) {
        const target = document.querySelector(href.substring(1));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>
